[configuration]
entry_symbol = "tree_sitter_gd_init"
compatibility_minimum = "4.1"
reloadable = true

[libraries]
; macOS — godot-cpp builds a universal binary by default
macos.debug   = "res://addons/tree_sitter_gd/bin/libtree_sitter_gd.macos.template_debug.universal.dylib"
macos.release = "res://addons/tree_sitter_gd/bin/libtree_sitter_gd.macos.template_release.universal.dylib"

; Linux
linux.debug.x86_64   = "res://addons/tree_sitter_gd/bin/libtree_sitter_gd.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/tree_sitter_gd/bin/libtree_sitter_gd.linux.template_release.x86_64.so"

; Windows
windows.debug.x86_64   = "res://addons/tree_sitter_gd/bin/libtree_sitter_gd.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/tree_sitter_gd/bin/libtree_sitter_gd.windows.template_release.x86_64.dll"
